# Per-user Claude Code settings (not shared)
.claude/settings.local.json

# macOS (github/gitignore · Global/macOS.gitignore)
.DS_Store
._*
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# Node / npm — only the dev-time lint toolchain uses these
# (github/gitignore · Node.gitignore)
node_modules/
.npm
.eslintcache
.stylelintcache
*.log
*.tgz

# Link checker (lychee runs with cache = true; see lychee.toml)
.lycheecache

# Playwright browser smoke tests (artifacts, not the specs)
/test-results/
/playwright-report/
/blob-report/
/.playwright/

# Local env / secrets
.env
.env.*

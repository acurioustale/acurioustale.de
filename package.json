{
  "name": "acurioustale.de",
  "private": true,
  "type": "module",
  "description": "Lint tooling for the acurioustale.de landing page. The site itself has no build step; this only provides ESLint and markdownlint-cli2, which are npm-only.",
  "scripts": {
    "lint:js": "eslint .",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:md": "markdownlint-cli2",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:md",
    "test": "node --test",
    "check:csp": "node tools/check-csp.mjs",
    "check:og": "node tools/check-og-image.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-html": "^8.1.4",
    "globals": "^17.7.0",
    "markdownlint-cli2": "^0.22.1",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "svgo": "^4.0.1"
  },
  "overrides": {
    "markdown-it": "^14.2.0"
  }
}
